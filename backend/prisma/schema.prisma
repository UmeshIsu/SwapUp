generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum MessageType {
  TEXT
  SWAP_REQUEST
}

enum SwapStatus {
  PENDING
  ACCEPTED_BY_EMPLOYEE
  DECLINED_BY_EMPLOYEE
  APPROVED_BY_MANAGER
  REJECTED_BY_MANAGER
}

// ==========================================
// CORE — ORGANIZATION
// ==========================================

model Tenant {
  id          String @id @default(uuid()) @db.Uuid
  companyName String @unique

  createdAt DateTime @default(now())

  users       User[]
  departments Department[]
  siteQrCode  SiteQrCode?
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  tenantId  String   @db.Uuid
  managerId String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id])
  manager User?  @relation("ManagedDepartments", fields: [managerId], references: [id])
  users   User[] @relation("UserDepartment")

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ==========================================
// USERS
// ==========================================

model User {
  id       String  @id @default(uuid()) @db.Uuid
  workerId String  @unique
  role     Role
  tenantId String  @db.Uuid
  name     String
  email    String  @unique
  phone    String  @unique
  password String?

  // Profile
  avatarUrl               String?
  plan                    String  @default("Basic")
  availabilityPreferences String?
  fcmToken                String?

  // Department FK (replaces old Department enum column)
  departmentId String?     @db.Uuid
  department   Department? @relation("UserDepartment", fields: [departmentId], references: [id])

  // Admin lifecycle fields
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  invitedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant         @relation(fields: [tenantId], references: [id])
  managedDepartments Department[]   @relation("ManagedDepartments")
  createdShifts      Shift[]        @relation("CreatedByManager")
  shifts             Shift[]        @relation("EmployeeShifts")
  participants       Participant[]
  messages           Message[]      @relation("SentMessages")
  swapRequestsAsRequester SwapRequest[] @relation("RequesterSwaps")
  swapRequestsAsTarget    SwapRequest[] @relation("TargetSwaps")
  leaveRequests      LeaveRequest[]
  attendances        Attendance[]

  @@index([tenantId])
}

// ==========================================
// SCHEDULE & SHIFTS
// ==========================================

model Shift {
  id         String   @id @default(uuid()) @db.Uuid
  date       DateTime @db.Date
  startTime  DateTime
  endTime    DateTime
  employeeId String   @db.Uuid
  createdBy  String   @db.Uuid

  instructions  String?
  type          String?
  location      String?
  role          String?
  actualCheckIn DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee User @relation("EmployeeShifts", fields: [employeeId], references: [id], onDelete: Cascade)
  creator  User @relation("CreatedByManager", fields: [createdBy], references: [id], onDelete: Restrict)

  swapRequestsAsRequester SwapRequest[] @relation("RequesterShift")
  swapRequestsAsTarget    SwapRequest[] @relation("TargetShift")

  @@index([employeeId, date])
}

// ==========================================
// ATTENDANCE
// ==========================================

model Attendance {
  id           Int       @id @default(autoincrement())
  userId       String    @db.Uuid
  checkedInAt  DateTime  @default(now())
  lat          Float
  lng          Float
  accuracy     Float
  checkedOutAt DateTime?
  status       String
  rejectReason String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// QR CODE CONFIG PER HOTEL
// ==========================================

model SiteQrCode {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @unique @db.Uuid
  qrToken   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ==========================================
// CHAT
// ==========================================

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now())

  participants Participant[]
  messages     Message[]
}

model Participant {
  id             String @id @default(uuid()) @db.Uuid
  userId         String @db.Uuid
  conversationId String @db.Uuid

  user         User         @relation(fields: [userId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@unique([userId, conversationId])
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  conversationId String      @db.Uuid
  senderId       String      @db.Uuid
  content        String
  type           MessageType @default(TEXT)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
  swapRequest  SwapRequest?
}

// ==========================================
// SMART SWAP
// ==========================================

model SwapRequest {
  id               String     @id @default(uuid()) @db.Uuid
  messageId        String?    @unique @db.Uuid
  requesterId      String     @db.Uuid
  targetId         String     @db.Uuid
  requesterShiftId String     @db.Uuid
  targetShiftId    String     @db.Uuid
  status           SwapStatus @default(PENDING)
  reason           String     @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  message        Message? @relation(fields: [messageId], references: [id])
  requester      User     @relation("RequesterSwaps", fields: [requesterId], references: [id])
  target         User     @relation("TargetSwaps", fields: [targetId], references: [id])
  requesterShift Shift    @relation("RequesterShift", fields: [requesterShiftId], references: [id])
  targetShift    Shift    @relation("TargetShift", fields: [targetShiftId], references: [id])
}

// ==========================================
// LEAVE MANAGEMENT
// ==========================================

model LeaveType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  totalDays Int
  createdAt DateTime @default(now())

  leaveRequests LeaveRequest[]
}

model LeaveRequest {
  id          String   @id @default(uuid()) @db.Uuid
  employeeId  String   @db.Uuid
  leaveTypeId String   @db.Uuid
  startDate   DateTime
  endDate     DateTime
  dayType     String   @default("full")
  reason      String   @default("")
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  employee  User      @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])
}